FIREWORKS_API_KEY=your-key-here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=accounts/fireworks/models/minimax-m3,accounts/fireworks/models/kimi-k2p7-code,accounts/fireworks/models/gemma-4-31b-it,accounts/fireworks/models/gemma-4-26b-a4b-it,accounts/fireworks/models/gemma-4-31b-it-nvfp4

# Leave "false" for all local dev/testing. Gemma models on this account
# incur a ~$20 one-time deployment cost the first time each variant is
# invoked - only flip to "true" deliberately, once, for the bonus-qualifying
# run (routes the sentiment category to gemma-4-26b-a4b-it, the cheapest
# variant). Never leave "true" while iterating locally.
ENABLE_GEMMA_BONUS=false
